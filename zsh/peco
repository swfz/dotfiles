# claude plan„Éē„ā°„ā§„Éę„āí„āŅ„ā§„Éą„Éę„ĀßťĀłśäě„Āó„Ā¶„ÉĎ„āĻ„āíŚáļŚäõ
function peco-claude-plan () {
  local plan_dir="$HOME/.claude/plans"
  [[ -d "$plan_dir" ]] || return
  local selected="$(for f in "$plan_dir"/*.md(N); do
    local title="$(head -1 "$f" | sed 's/^# //')"
    local date="$(stat -f '%Sm' -t '%Y-%m-%d' "$f")"
    printf "%s\t%s\t%s\n" "$date" "$title" "$f"
  done | sort -r | fzf-popup --delimiter='\t' --with-nth=1,2 --preview 'bat --color=always --style=numbers {3}' --preview-window right,65% --bind 'ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up' | awk -F'\t' '{print $3}')"
  peco-p ${selected}
}
zle -N peco-claude-plan
bindkey '^gcp' peco-claude-plan

# claude sessionŚÖĪťÄöťĀłśäě„Éė„Éę„ÉĎ„Éľ(„āŅ„ÉĖŚĆļŚąá„āäŤ°Ć„āíŤŅĒ„Āô)
function _peco-claude-session-select() {
  local projects_dir="$HOME/.claude/projects"
  [[ -d "$projects_dir" ]] || return
  python3 -c "
import json,os,glob,datetime,re
projects_dir='$projects_dir'
summary_map={}
for idx in glob.glob(os.path.join(projects_dir,'*/sessions-index.json')):
    try:
        with open(idx) as f:
            data=json.load(f)
        for e in data.get('entries',[]):
            sid=e.get('sessionId','')
            s=e.get('summary','')
            if sid and s:summary_map[sid]=s
    except:pass
results=[]
for proj_dir in glob.glob(os.path.join(projects_dir,'*/')):
    dirname=os.path.basename(proj_dir.rstrip('/'))
    if dirname=='memory':continue
    proj_name=None
    for f in sorted(glob.glob(os.path.join(proj_dir,'*.jsonl'))):
        sid=os.path.splitext(os.path.basename(f))[0]
        mtime=os.path.getmtime(f)
        date=datetime.datetime.fromtimestamp(mtime).strftime('%Y-%m-%d')
        title=summary_map.get(sid,'')
        try:
            with open(f) as fh:
                for line in fh:
                    msg=json.loads(line)
                    if not proj_name and 'cwd' in msg:
                        proj_name=os.path.basename(msg['cwd'])
                    if not title and msg.get('type')=='user':
                        c=msg.get('message',{}).get('content','')
                        t=c if isinstance(c,str) else next((x.get('text','') for x in c if x.get('type')=='text'),'')
                        t=t.replace('\n',' ').replace('\t',' ').strip()
                        t=re.sub(r'<[^>]+>[^<]*</[^>]+>','',t).strip()[:80]
                        if t and not t.startswith('<'):title=t
                    if proj_name and title:break
            with open(f) as fh2:
                for tl in fh2:
                    if '"custom-title"' in tl:
                        tm=json.loads(tl)
                        if tm.get('type')=='custom-title':title=tm.get('customTitle','')
        except:pass
        if not title:title='(no title)'
        pn=proj_name or dirname
        results.append((date,pn,title,f))
results.sort(key=lambda x:x[0],reverse=True)
for d,p,t,f in results:
    print(f'{d}\t[{p}] {t}\t{f}')
" 2>/dev/null | fzf-popup --delimiter='\t' --with-nth=1,2 --preview 'claude-session-preview {3}' --preview-window right,50%,follow --bind 'ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up'
}

# claude session„Éē„ā°„ā§„Éę„āí„Éó„É≠„āł„āß„āĮ„ÉąŚźć+„āŅ„ā§„Éą„Éę„ĀßťĀłśäě„Āó„Ā¶„ÉĎ„āĻ„āíŚáļŚäõ
function peco-claude-session () {
  local selected="$(_peco-claude-session-select | awk -F'\t' '{print $3}')"
  peco-p ${selected}
}
zle -N peco-claude-session
bindkey '^gcs' peco-claude-session

