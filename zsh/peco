# fzf-popup: fzf„āítmux popup„ĀßŚģüŤ°Ć„Āô„āč„Éė„Éę„ÉĎ„Éľ
# Usage: echo "data" | fzf-popup [fzf_options...]
function fzf-popup() {
  if [[ -n "$TMUX" ]]; then
    fzf --tmux center,80%,80% "$@"
  else
    fzf "$@"
  fi
}

# peco
function peco-select-history() {
    local tac
    if which tac > /dev/null; then
        tac="tac"
    else
        tac="tail -r"
    fi
    selected=$(\history -n 1 | \
        eval $tac | \
        fzf-popup --scheme=history --query "$LBUFFER" --preview 'echo {} | sed "s/ \\\\n/\\n/g" | bat --color=always -l sh --style=plain' --preview-window down,30%,wrap | \
        sed s'/ \\\\n/ /g')
    BUFFER=$(echo "${selected}")
    zle redisplay
    CURSOR=$#BUFFER
    zle clear-screen
}
zle -N peco-select-history
bindkey '^r' peco-select-history

function csp () {
  unset CHEATCOLORS
  BUFFER=$( cheat $1 | grep -v '^#' | fzf-popup --query "$LBUFFER" )
  print -z "$BUFFER"
  export CHEATCOLORS=true
}

function tvi () {
  vim $( tree --charset=o -f $1 | fzf-popup | tr -d '\||`|-' )
}

function aliasp () {
  BUFFER=$(alias | fzf-popup --query "$LBUFFER" | awk -F"=" '{print $1}')
  print -z "$BUFFER"
}

function ssh-peco () {
  ssh $(grep --color=no 'Host ' ~/.ssh/config | fzf-popup | awk '{print $2}')
}

function peco-p() {
  selected=$@
  if [ -n "$selected" ]; then
    BUFFER="${BUFFER}${selected}"
    # „āę„Éľ„āĹ„ÉęšĹćÁĹģ„āíśúęŚįĺ„ĀęÁßĽŚčē
    CURSOR=$#BUFFER
  fi
}

# git branch„āíťĀłśäě
function peco-git-branch () {
  local selected_branch_name="$(git branch -a --color=always | fzf-popup | sed 's/\x1b\[[0-9;]*m//g' | tr -d ' ' | tr -d '*')"
  case "$selected_branch_name" in
    *-\>* )
      selected_branch_name="$(echo ${selected_branch_name} | perl -ne 's/^.*->(.*?)\/(.*)$/\2/;print')";;
    remotes* )
      selected_branch_name="$(echo ${selected_branch_name} | perl -ne 's/^.*?remotes\/(.*?)\/(.*)$/\2/;print')";;
  esac
  peco-p ${selected_branch_name}
}
zle -N peco-git-branch
bindkey '^gb' peco-git-branch

