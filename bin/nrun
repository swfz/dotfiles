#!/bin/bash

# notify and run script
# コマンドをラップしてデスクトップ通知 + tmux window/pane通知を送る

_usage(){
cat << EOS
usage:
  nrun command [option...]

script that wraps a command and sends a notification depending on the exit code
EOS
  exit 1
}

if [ -z "$*" ]; then
  _usage
fi

"$@"

exit_code=$?

if [ ${exit_code} -eq 0 ]; then
  result='Success'
  emoji='✅'
  pane_color='fg=colour46,bold'
else
  result='Failed'
  emoji='❌'
  pane_color='fg=colour196,bold'
fi

# デスクトップ通知
notify "$*" "${result}"

# tmux window/pane通知
if [ -n "$TMUX" ]; then
  # bell (window ステータスバーのハイライト用)
  echo -ne '\a'
  # window名に絵文字を付与(pane-focus-inフックで維持するため環境変数にも保存)
  tmux set-option -w -t "$TMUX_PANE" @nrun_emoji "$emoji"
  tmux rename-window "$(~/dotfiles/bin/tmux-window-name . "$emoji")"
  # pane border色を変更 (フォーカス時にリセットされる)
  tmux set-option -p pane-border-style "$pane_color"
fi
