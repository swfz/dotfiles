FROM ubuntu:resolute@sha256:3131b4cc82a783df6c9df078f86e01819a13594b865c2cad47bd1bca2b7063bb

RUN apt-get update \
    export DEBIAN_FRONTEND=noninteractive \
    apt-get install -y software-properties-common gpg-agent curl sudo tzdata \
    add-apt-repository ppa:deadsnakes/ppa -y \
    apt-get update \
    apt-get install -y python3.12 python3.12-venv \
    curl -LsSf https://astral.sh/uv/install.sh | sh \
    mv ~/.local/bin/uv /usr/local/bin/uv \
    uv venv --python python3.12 \
    uv pip install --no-cache ansible ansible-lint

WORKDIR /app

